# Found via find_package(NESTSimulator); defines NEST::nest (see
# cmake/NESTSimulatorConfigExport.cmake). GSL::gsl/Boost::headers/
# MPI::MPI_CXX/OpenMP::OpenMP_CXX are referenced by name in NEST::nest's
# link libraries, so a target by each name must exist here too.
#
# Deliberately NOT re-discovered via find_dependency(): that needs the
# consumer's machine to independently re-find each one (fragile -- e.g.
# NEST's own Homebrew libomp lookup isn't something find_dependency(OpenMP)
# replicates) and risks resolving a different install than NEST actually
# used. Instead each target's properties are NEST's own already-resolved
# values, baked in directly -- same approach nest-config's --includes/--libs
# output already uses.

if ( NOT TARGET GSL::gsl )
  add_library( GSL::gsl INTERFACE IMPORTED )
  if ( @HAVE_GSL@ )
    set_target_properties( GSL::gsl PROPERTIES
      INTERFACE_INCLUDE_DIRECTORIES "@GSL_INCLUDE_DIRS@"
      INTERFACE_LINK_LIBRARIES "@GSL_LIBRARIES@"
    )
  endif ()
endif ()

if ( NOT TARGET Boost::headers )
  add_library( Boost::headers INTERFACE IMPORTED )
  if ( @HAVE_BOOST@ )
    set_target_properties( Boost::headers PROPERTIES
      INTERFACE_INCLUDE_DIRECTORIES "@_boost_inc@"
    )
  endif ()
endif ()

if ( NOT TARGET MPI::MPI_CXX )
  add_library( MPI::MPI_CXX INTERFACE IMPORTED )
  if ( @HAVE_MPI@ )
    set_target_properties( MPI::MPI_CXX PROPERTIES
      INTERFACE_INCLUDE_DIRECTORIES "@MPI_CXX_INCLUDE_DIRS@"
      INTERFACE_LINK_LIBRARIES "@MPI_CXX_LIBRARIES@"
      INTERFACE_COMPILE_OPTIONS "@_nest_mpi_compile_options@"
    )
  endif ()
endif ()

if ( NOT TARGET OpenMP::OpenMP_CXX )
  add_library( OpenMP::OpenMP_CXX INTERFACE IMPORTED )
  if ( @OpenMP_FOUND@ )
    set_target_properties( OpenMP::OpenMP_CXX PROPERTIES
      INTERFACE_INCLUDE_DIRECTORIES "@OpenMP_CXX_INCLUDE_DIRS@"
      INTERFACE_LINK_LIBRARIES "@OpenMP_CXX_LIBRARIES@"
      INTERFACE_COMPILE_OPTIONS "@_nest_openmp_compile_options@"
    )
  endif ()
endif ()

# LTDL/LibNeurosim/MUSIC/SIONlib have no modern imported targets, so they're
# already plain absolute paths baked into NEST::nest -- nothing to do here.

include( "${CMAKE_CURRENT_LIST_DIR}/NESTSimulatorTargets.cmake" )
